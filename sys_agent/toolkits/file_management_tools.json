  {
    "name": "find_file",
    "description": "在指定目录及其子目录下查找文件，返回所有匹配的文件路径列表",
    "parameters": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string",
          "description": "要查找的文件名（支持部分匹配或全名）"
        },
        "path": {
          "type": "string",
          "description": "起始查找目录，默认为当前目录",
          "default": "."
        },
        "nums": {
          "type": "integer",
          "description": "最多返回的匹配文件数，-1表示不限制",
          "default": -1
        }
      },
      "required": ["filename"]
    },
    "returns": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "message": { "type": "string" },
        "found_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "一个包含所有找到的文件完整路径的列表。"
        }
      }
    }
